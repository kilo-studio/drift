# macOS
.DS_Store
.AppleDouble
.LSOverride

# Obsidian — workspace state, plugin caches, search index
.obsidian/

# Private notes — not for the public repo. Put any additional private
# scratch files alongside Notes.md or in a private/ folder.
Notes.md
private/

# Internal planning + assistant-orientation docs — kept locally so day-to-day
# work doesn't change, but not published when the repo goes public.
CLAUDE.md
Plan.md
Case study.md

# Claude Code session-local state (scheduled tasks, local settings)
.claude/

# Personal prototype data — the live Scriptable hit log. Real personal usage
# data; never published. The re-sync command (see CLAUDE.md) copies this in,
# so it must stay ignored. The .js prototype scripts ARE tracked (code, not data).
prototype/vape-log.json

# Personal prototype data bundled for one-time import on the dev device.
# Real users would use a UIDocumentPicker flow instead (see Issue 05).
**/Resources/vape-log-bundle.json

# Local rescue / backup data — recovered SQLite stores, JSON exports of
# personal hits, etc. Never goes public; lives alongside the repo for
# convenience only.
/Resources/
**/Resources/rescue/

# Xcode (will apply once app/ exists)
**/xcuserdata/
**/build/
**/.build/
**/*.xcuserstate
**/DerivedData/

# Swift Package Manager
**/Package.resolved
**/.swiftpm/

# Fastlane / TestFlight build artifacts
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots/**/*.png
**/fastlane/test_output

# CocoaPods (if ever used)
**/Pods/

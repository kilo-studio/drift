<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Lets canOpenURL("shortcuts://") report whether the system Shortcuts
	     app is installed, so onboarding can offer to install it when missing.
	     All other Info.plist keys are still generated (GENERATE_INFOPLIST_FILE)
	     and merged on top of this base. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>shortcuts</string>
	</array>
	<!-- CloudKit pushes silent notifications so SwiftData can pull synced
	     changes in the background; without this background mode CloudKit logs
	     "BUG IN CLIENT OF CLOUDKIT: ... require the 'remote-notification'
	     background mode" and only syncs on launch/foreground. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
